# SMTP configuration for email sending
# Supported providers: Gmail (smtp.gmail.com), Outlook/Office365 (smtp.office365.com)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Your Name <your-email@gmail.com>

# Azure AD for Microsoft 365 MCP (SharePoint / OneDrive)
# Register an app at https://portal.azure.com → App registrations
# Add permissions: Files.Read.All, Sites.Read.All, User.Read
AZURE_CLIENT_ID=your-client-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_SECRET=your-client-secret
