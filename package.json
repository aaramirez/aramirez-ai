{
  "name": "aramirez-ai",
  "version": "1.0.0",
  "description": "Centralized AI agent configuration: opencode, claude, cursor, codex",
  "type": "module",
  "bin": {
    "arai": "bin/arai.js"
  },
  "scripts": {
    "install:opencode": "arai install opencode --global",
    "install:claude": "arai install claude --global",
    "install:cursor": "arai install cursor --global",
    "transform": "arai transform skills --all",
    "status": "arai status",
    "update": "arai update",
    "init": "arai init",
    "templates": "arai template list",
    "docgen:deck": "node shared/scripts/docgen/build-deck.js",
    "docgen:report": "node shared/scripts/docgen/build-report.js",
    "docgen:image": "node shared/scripts/docgen/build-image.js",
    "docgen:web": "node shared/scripts/docgen/build-web.js",
    "docgen:pptx": "node shared/scripts/docgen/build-pptx.js",
    "docgen:validate": "node shared/scripts/docgen/validate.js"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
