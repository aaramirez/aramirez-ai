{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "description": "Default build agent for coding tasks",
      "mode": "primary"
    },
    "docs": {
      "description": "Documentation specialist. Use for README, docs, and changelogs.",
      "mode": "subagent",
      "permission": {
        "bash": "deny",
        "edit": "allow"
      }
    },
    "plan": {
      "description": "Planning agent for architecture and design",
      "mode": "primary",
      "permission": {
        "edit": "deny"
      }
    },
    "plan-arai": {
      "description": "Modo de Planificación de arai, edita solo plans/",
      "mode": "primary",
      "path": ".opencode/agents/plan-arai.md"
    },
    "reviewer": {
      "description": "Code review specialist. Use for PR reviews and quality checks.",
      "mode": "subagent",
      "permission": {
        "edit": "deny"
      }
    },
    "tester": {
      "description": "Testing specialist. Use for writing and running tests.",
      "mode": "subagent",
      "permission": {
        "bash": "allow"
      }
    },
    "new-harness": {
      "description": "Generador interactivo de harnesses de opencode",
      "mode": "primary",
      "path": ".opencode/agents/new-harness.md"
    },
    "config-creator": {
      "description": "Genera configuraciones opencode.json personalizadas",
      "mode": "subagent",
      "path": ".opencode/agents/config-creator.md"
    },
    "permission-creator": {
      "description": "Genera configuraciones de permisos con diferentes niveles de estrictitud",
      "mode": "subagent",
      "path": ".opencode/agents/permission-creator.md"
    },
    "instructions-creator": {
      "description": "Genera AGENTS.md personalizado según el tipo y lenguaje del proyecto",
      "mode": "subagent",
      "path": ".opencode/agents/instructions-creator.md"
    },
    "mcp-creator": {
      "description": "Genera configuraciones de servidores MCP locales o remotos",
      "mode": "subagent",
      "path": ".opencode/agents/mcp-creator.md"
    },
    "architecture-creator": {
      "description": "Genera documentación de arquitectura de software",
      "mode": "subagent",
      "path": ".opencode/agents/architecture-creator.md"
    },
    "flow-creator": {
      "description": "Genera flujos de trabajo y pipelines de automatización",
      "mode": "subagent",
      "path": ".opencode/agents/flow-creator.md"
    },
    "plugin-creator": {
      "description": "Genera plugins de TUI para opencode",
      "mode": "subagent",
      "path": ".opencode/agents/plugin-creator.md"
    },
    "tool-creator": {
      "description": "Genera herramientas personalizadas para agentes",
      "mode": "subagent",
      "path": ".opencode/agents/tool-creator.md"
    },
    "prompt-creator": {
      "description": "Genera prompts reutilizables para agentes",
      "mode": "subagent",
      "path": ".opencode/agents/prompt-creator.md"
    },
    "rule-creator": {
      "description": "Genera reglas de código y estándares de codificación",
      "mode": "subagent",
      "path": ".opencode/agents/rule-creator.md"
    },
    "reference-creator": {
      "description": "Genera referencias a repositorios y documentación externa",
      "mode": "subagent",
      "path": ".opencode/agents/reference-creator.md"
    },
    "command-creator": {
      "description": "Genera comandos personalizados de opencode",
      "mode": "subagent",
      "path": ".opencode/agents/command-creator.md"
    }
  },
  "command": {
    "commit": {
      "description": "Create a conventional commit",
      "template": "Stage all changes and create a conventional commit with an appropriate type and scope based on the changes."
    },
    "deploy": {
      "description": "Deploy current project",
      "template": "Deploy the current project. Check the project type and deployment config, then execute the appropriate deploy command."
    },
    "test": {
      "description": "Run test suite for current project",
      "template": "Run the test suite for this project. First detect the test framework, then run all tests and report results."
    },
    "email": {
      "description": "Send an email using project SMTP configuration.",
      "template": "Understand the email requirements from the user. Build a JSON payload with 'to', 'subject', 'body', and optionally 'cc', 'bcc', 'html', 'attachments'. Write it to .opencode/email-payload.json. Then run: node shared/scripts/send-email.js --payload .opencode/email-payload.json. Report success or error."
    }
  },
  "compaction": {
    "auto": true,
    "tail_turns": 10
  },
  "default_agent": "build",
  "formatter": true,
  "instructions": [
    "AGENTS.md"
  ],
  "lsp": true,
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "engram": {
      "command": [
        "/usr/local/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    "github": {
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      },
      "type": "remote",
      "url": "https://api.github.com/mcp"
    },
    "playwright": {
      "command": [
        "npx",
        "-y",
        "@playwright/mcp"
      ],
      "enabled": false,
      "env": {},
      "type": "local"
    },
    "email": {
      "command": [
        "node",
        "shared/scripts/mcp-email.js"
      ],
      "enabled": false,
      "type": "local"
    },
    "google-workspace": {
      "command": [
        "npx",
        "-y",
        "@google/mcp-workspace"
      ],
      "enabled": false,
      "type": "local"
    },
    "m365": {
      "command": [
        "npx",
        "-y",
        "@softeria/ms-365-mcp-server"
      ],
      "enabled": false,
      "env": {
        "AZURE_CLIENT_ID": "{env:AZURE_CLIENT_ID}",
        "AZURE_TENANT_ID": "{env:AZURE_TENANT_ID}",
        "AZURE_CLIENT_SECRET": "{env:AZURE_CLIENT_SECRET}",
        "M365_READ_ONLY_MODE": "true"
      },
      "type": "local"
    }
  },
  "model": "opencode/big-pickle",
  "permission": {
    "bash": {
      "*": "allow",
      "git *": "allow",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask",
      "npm *": "allow",
      "npx *": "ask"
    },
    "edit": "ask",
    "read": {
      "*": "allow",
      "**/*.key": "deny",
      "**/*.pem": "deny",
      "**/.aws/credentials": "deny",
      "**/.config/gh/hosts.yml": "deny",
      "**/.credentials/**": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/.ssh/**": "deny",
      "**/Library/Keychains/**": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  },
  "references": {
    "shared-prompts": {
      "description": "Reusable prompt fragments for common patterns",
      "path": "../shared/prompts"
    },
    "shared-rules": {
      "description": "Coding standards, architecture, and documentation rules",
      "path": "../shared/rules"
    },
    "shared-scripts": {
      "description": "Reusable automation scripts (deploy, test, etc.)",
      "path": "../shared/scripts"
    }
  },
  "shell": "/bin/zsh",
  "skills": {
    "paths": [
      ".opencode/skills",
      "~/.config/opencode/skills",
      "../shared/skills"
    ]
  },
  "small_model": "anthropic/claude-haiku-4-5",
  "tool_output": {
    "max_bytes": 40960,
    "max_lines": 1000
  }
}
